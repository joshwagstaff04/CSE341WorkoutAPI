            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new exercise",
        "tags": ["Exercises"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
